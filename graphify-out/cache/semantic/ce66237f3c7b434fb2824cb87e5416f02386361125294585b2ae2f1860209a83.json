{"nodes": [{"id": "claude_skills_graphify_skill_graphify", "label": "/graphify Skill (SKILL.md)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_skills_graphify_skill_pipeline_steps", "label": "Graphify Build Pipeline (Steps 0-9)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_skills_graphify_skill_honesty_rules", "label": "Graphify Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge, always show token cost, never hide cohesion scores, warn before HTML viz on >5000 nodes - keeps the audit trail honest (EXTRACTED/INFERRED/AMBIGUOUS) rather than presenting a polished but unverifiable graph."}, {"id": "claude_skills_graphify_skill_query_fast_path", "label": "Fast Path: Existing Graph Query", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json already exists and the user asks a natural-language question, skip Steps 1-5 and query directly - avoids re-running the expensive extraction pipeline for a question the existing graph can already answer."}], "edges": [{"source": "claude_skills_graphify_skill_graphify", "target": "claude_skills_graphify_skill_pipeline_steps", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "claude_skills_graphify_skill_graphify", "target": "claude_skills_graphify_skill_honesty_rules", "rel
{"nodes": [{"id": "claude_skills_graphify_references_query_query_expansion", "label": "Constrained Query Vocabulary Expansion", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "graphify's matcher is case-folded substring + IDF with no stemming, synonyms, or cross-language match, so a wording mismatch between the user's question and the graph's node-label vocabulary collapses the answer to zero hits; expanding the query against the graph's own extracted vocabulary first (never inventing tokens) fixes this without hallucinating search terms."}, {"id": "claude_skills_graphify_references_query_bfs_dfs", "label": "BFS/DFS Traversal Modes", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_skills_graphify_references_query_path", "label": "/graphify path", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_skills_graphify_references_query_explain", "label": "/graphify explain", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_skills_graphify_references_query_work_memory", "label": "Work Memory (save-result / reflect / LESSONS.md)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Saves query outcomes (useful/dead_end/corrected) back into the graph so future sessions prefer known-good sources and skip known dead ends - a self-improving feedback loop."}], "edges": [{"source": "claude_skills_graphify_references_query_bfs_dfs", "target": "claude_skills_graphify_references_query_path", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "claude_skills_graphify_references_query_path", "target": "claude_skills_graphify_references_query_explain", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "claude_skills_graphify_references_query_query_expansion", "target": "claude_skills_graphify_references_query_work_memory", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}], "hyperedges": []}